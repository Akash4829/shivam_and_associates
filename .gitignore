# Dependencies
node_modules/

# Environment & secrets (keep *.example for templates)
.env
.env.*
!.env.example

# Build output
build/
dist/
*.tsbuildinfo

# Logs & debug
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Test & coverage
coverage/
.nyc_output/

# Caches
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.cache

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# Editor / IDE
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# VS Code — ignore local settings, keep shared config if added later
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example

# Optional local tooling
*.local

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Package manager (optional lockfile policy — lockfiles are usually committed)
# Uncomment if you prefer not to track lockfiles:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
