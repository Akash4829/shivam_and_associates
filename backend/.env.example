NODE_ENV=production
PORT=5000
CLIENT_URL=https://yourdomain.com

# PostgreSQL (use DATABASE_URL or individual vars)
DATABASE_URL=postgresql://user:password@host:5432/database
DB_USER=postgres
DB_HOST=localhost
DB_NAME=lawfirm_db
DB_PASSWORD=replace_with_secure_password
DB_PORT=5432

# Security
JWT_SECRET=replace_with_secure_random_string
JWT_EXPIRES_IN=7d
SESSION_SECRET=replace_with_secure_random_string
# Auth cookie SameSite policy.
#   - Leave unset for: 'none' in production (required when the frontend and API
#     are on DIFFERENT domains, e.g. Vercel + Render) / 'lax' in development.
#   - Set to 'lax' if the frontend and API are served from the SAME domain.
COOKIE_SAMESITE=

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email (password reset, notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Shivam Mishra & Associates" <noreply@yourdomain.com>
FIRM_EMAIL=advshivammishra2124@gmail.com
