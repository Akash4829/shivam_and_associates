PORT=5000
# Must match the password for DB_USER in PostgreSQL (e.g. the one you set at install on Windows).
# You can also set the standard PGPASSWORD var instead of DB_PASSWORD.
DB_USER=postgres
DB_HOST=localhost
DB_NAME=lawfirm_db
DB_PASSWORD=root
DB_PORT=5432
# If set, used as full connection URL (e.g. Neon). Leave empty to use DB_* vars above.
DATABASE_URL=
JWT_SECRET=generate_a_strong_random_secret_here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=advshivammishra2124@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Shivam Mishra and Associates" <noreply@lawfirm.com>
CLIENT_URL=http://localhost:3000
# Comma-separated list of allowed frontend origins (preferred in production)
CLIENT_URLS=http://localhost:3000
