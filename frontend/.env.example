# Local development
REACT_APP_API_URL=http://localhost:5000

# Production (Vercel) — choose ONE approach:
#
# A) Direct Railway URL:
#    REACT_APP_API_URL=https://shivamandassociates-production.up.railway.app
#    Railway must allow your Vercel origin (CLIENT_URL / CLIENT_URLS / ALLOW_VERCEL_PREVIEWS)
#
# B) Same-origin proxy (avoids CORS — recommended):
#    1. frontend/vercel.json already proxies /api/* to Railway
#    2. Remove REACT_APP_API_URL on Vercel (or set it to your Vercel site URL)
#    3. Redeploy Vercel

# Google Sign-In (Vercel: must be REACT_APP_ prefix, then redeploy)
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Optional — Google One Tap on homepage (default off; can conflict with sign-in button)
# REACT_APP_GOOGLE_ONE_TAP=true

REACT_APP_APPLE_CLIENT_ID=your.apple.services.id

# Google Cloud Console → Authorized JavaScript origins (exact URLs, no trailing slash):
#   http://localhost:3000
#   https://your-vercel-domain.vercel.app
